# ========================================
# AdaptiveIQ Backend Configuration
# ========================================
# WARNING: Never commit actual secrets!
# Copy this to .env and fill in your values

# ========================================
# Server
# ========================================
NODE_ENV=development
PORT=5001

# ========================================
# MongoDB Configuration
# ========================================
# Local MongoDB:
# MONGODB_URI=mongodb://127.0.0.1:27017/adaptiveiq

# MongoDB Atlas (Production):
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/adaptiveiq?retryWrites=true&w=majority

# ========================================
# Groq AI (for AI quiz generation)
# ========================================
GROQ_API_KEY=your_groq_api_key_here

# ========================================
# JWT Authentication
# ========================================
JWT_SECRET=your_jwt_secret_key_here_use_long_random_string

# ========================================
# CORS (Frontend URL)
# ========================================
CLIENT_URL=http://localhost:5173
LOG_FILE=./logs/app.log
LOG_ERROR_FILE=./logs/error.log

# ========================================
# External Services & API Keys
# ========================================
# Add your API keys here
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# STRIPE_SECRET_KEY=
# SENDGRID_API_KEY=
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# ========================================
# PRODUCTION DEPLOYMENT CHECKLIST
# ========================================
# [ ] Change NODE_ENV to 'production'
# [ ] Generate secure JWT_SECRET (64+ characters)
# [ ] Update database credentials
# [ ] Set proper CORS_ORIGIN
# [ ] Enable rate limiting
# [ ] Configure HTTPS
# [ ] Set SESSION_SECURE=true (if using sessions)
# [ ] Review and update all API keys
# [ ] Setup monitoring and logging
# [ ] Configure backup strategy
# [ ] Test error handling
